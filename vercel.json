{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pnpm install",
  "buildCommand": "pnpm --filter @hotsos/api build:vercel && pnpm --filter @hotsos/web build",
  "outputDirectory": "apps/web/dist",
  "functions": {
    "api/[...route].mjs": {
      "maxDuration": 60
    }
  }
}
